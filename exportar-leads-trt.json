            "paginationCompleteWhen": "other",
            "completeExpression": "={{ !$response.body.hasMore }}"
          }
        }
      },
      "id": "node-002",
      "name": "Buscar Todas as Execuções",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "const allLeads = [];\n\n// Nomes possíveis do nó webhook neste workflow\nconst webhookNodeNames = ['Webhook - Projeto TRT2', 'Webhook - Projeto TRT'];\n\nfor (const page of $input.all()) {\n  const executions = page.json.data || [];\n\n  for (const exec of executions) {\n    try {\n      const runData = exec.data?.resultData?.runData || {};\n\n      // Encontra o nó webhook disponível\n      let webhookData = null;\n      for (const nodeName of webhookNodeNames) {\n        if (runData[nodeName]) {\n          webhookData = runData[nodeName];\n          break;\n        }\n      }\n      if (!webhookData) continue;\n\n      const rawJson = webhookData[0]?.data?.main?.[0]?.[0]?.json;\n      if (!rawJson) continue;\n\n      const body = typeof rawJson.body === 'string' ? JSON.parse(rawJson.body) : (rawJson.body || {});\n      const lead = body.lead || {};\n      const utms = body.utms || {};\n      const meta = body.meta || {};\n\n      const timestamp = meta.timestamp ? new Date(meta.timestamp) : new Date(exec.startedAt);\n      const dataInscricao = timestamp.toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo' });\n      const horaInscricao = timestamp.toLocaleTimeString('pt-BR', { timeZone: 'America/Sao_Paulo', hour12: false });\n\n      allLeads.push({\n        json: {\n          'Data de Inscrição': dataInscricao,\n          'Hora': horaInscricao,\n          'Email': lead.email || '',\n          'Nome': lead.name || '',\n          'Telefone': lead.phone || '',\n          'Página de Captura': meta.page_url || '',\n          'Pesquisa': meta.referrer || '',\n          'Grupo': '',\n          'utm_campaign': utms.utm_campaign || '',\n          'utm_medium': utms.utm_medium || '',\n          'utm_source': utms.utm_source || '',\n          'utm_content': utms.utm_content || '',\n          'utm_term': utms.utm_term || ''\n        }\n      });\n    } catch (e) {\n      // execução sem dados válidos, ignorar\n    }\n  }\n}\n\nif (allLeads.length === 0) {\n  return [{ json: { info: 'Nenhum lead encontrado nas execuções' } }];\n}\n\nreturn allLeads;"
      },
      "id": "node-003",
      "name": "Extrair Leads",
