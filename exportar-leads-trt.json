          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "workflowId",
              "value": "dxpSja1hYCK4nPdz"
            },
            {
              "name": "limit",
              "value": "100"
            },
            {
              "name": "includeData",
              "value": "true"
            }
          ]
        },
        "options": {
          "pagination": {
            "paginationMode": "updateAQueryParameter",
            "parameters": {
              "parameters": [
                {
                  "type": "query",
                  "name": "cursor",
                  "value": "={{ $response.body.nextCursor }}"
                }
              ]
